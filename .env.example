# Set either ANALYTICS_ADMIN_TOKEN or ANALYTICS_ADMIN_TOKEN_HASH.
ANALYTICS_ADMIN_TOKEN=change-this-admin-token
ANALYTICS_ADMIN_TOKEN_HASH=
ANALYTICS_SALT=change-this-random-salt
# Canonical public URL used for canonical tags, sitemap/RSS, redirects, and secure cookies.
SITE_ORIGIN=https://get-crypto.org
# Comma-separated hosts that should permanently redirect to SITE_ORIGIN.
LEGACY_HOSTS=japan-crypto-information.onrender.com
# Optional: use Neon Postgres for volume/sales snapshot history.
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Optional: analytics and local fallback JSON files. In production, use an absolute path such as /var/data.
DATA_DIR=./data
# Optional: exchange detail and campaign pages can render affiliate / referral buttons when set.
OKJ_REFERRAL_URL=https://www.okcoin.jp/account/join?invitation=C250678&type=0
COINCHECK_REFERRAL_URL=
BITFLYER_REFERRAL_URL=https://bitflyer.com/invitation?id=ml1wjtkl&lang=ja-JP
BITBANK_REFERRAL_URL=
GMO_COIN_REFERRAL_URL=
BINANCE_JAPAN_REFERRAL_URL=https://s.binance.com/OKkHnAGC?ref=GRO_55250_0VBAH
BITTRADE_REFERRAL_URL=https://www.bittrade.co.jp/ja-jp/register/?invite_code=tHc3p
