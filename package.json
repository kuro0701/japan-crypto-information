{
  "name": "japan-crypto-information",
  "version": "1.0.0",
  "description": "成行取引リアルタイム板シミュレーター",
  "main": "server.js",
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "npm run test:unit && npm run test:smoke",
