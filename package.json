    "test:smoke": "node --test --test-concurrency=1 ./test/smoke/*.test.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "marked": "^18.0.2",
    "pg": "^8.20.0",
    "ws": "^8.18.0"
  }
}
